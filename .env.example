# ─────────────────────────────────────────────────────────────
# Parahawk configuration. Copy to .env and fill in.
# The whole system runs with ZERO credentials when MOCK_DATA=true (the default).
# ─────────────────────────────────────────────────────────────

# --- Run mode -------------------------------------------------
# When true, all external data (Parasite + mempool) comes from fixtures,
# pollers write synthetic samples, and no credentials are required.
# Leave true until you have real endpoints + keys. Default: true.
MOCK_DATA=true

# HTTP port for the stats website.
PORT=3000

# Public base URL of the site (e.g. https://parahawk.example.com). Used for
# links in Discord embeds. Falls back to http://localhost:PORT when unset.
PUBLIC_BASE_URL=

# --- Tip jar --------------------------------------------------
# Your Lightning address (LNURL / lightning address form: name@domain).
# Shown in every Discord embed footer and the site footer, with a QR code.
LIGHTNING_ADDRESS=

# --- Discord bot ----------------------------------------------
# From https://discord.com/developers/applications
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Channel ID where block alerts are posted (right-click channel → Copy ID).
ALERT_CHANNEL_ID=
# Optional: restrict slash-command registration to one guild for instant updates.
DISCORD_GUILD_ID=
# Set false to run the website + pollers without starting the Discord bot.
ENABLE_BOT=true

# --- Supabase (Postgres) --------------------------------------
# From your Supabase project → Settings → API.
# Leave blank in mock mode to use the in-memory store (charts still work).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Parasite Pool API (undocumented — fill from devtools XHR) -
# Base URL + paths for the real endpoints. Ignored while MOCK_DATA=true.
PARASITE_BASE_URL=
PARASITE_POOL_STATS_PATH=/api/pool
PARASITE_USER_STATS_PATH=/api/user
PARASITE_REFINERY_PATH=/api/refinery

# --- mempool.space (documented, free) -------------------------
MEMPOOL_BASE_URL=https://mempool.space/api

# --- Pollers --------------------------------------------------
# Seconds between data collection cycles.
POLL_INTERVAL_SECONDS=45
# Seconds between block-alert checks.
BLOCK_POLL_INTERVAL_SECONDS=30
